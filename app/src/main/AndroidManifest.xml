<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".CineflowApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cineflow"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.player.PlayerActivity"
            android:configChanges="orientation|screenSize" />
        <activity
            android:name=".ui.detail.FilmDetailActivity"
            android:theme="@style/Theme.Cineflow.NoActionBar" />
        <activity
            android:name=".ui.admin.AdminDashboardActivity"
            android:theme="@style/Theme.Cineflow.Admin" />
        <activity
            android:name=".ui.admin.AdminFilmListActivity"
            android:theme="@style/Theme.Cineflow.Admin" />
        <activity
            android:name=".ui.auth.LoginActivity"
            android:theme="@style/Theme.Cineflow.Admin" />
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:theme="@style/Theme.Cineflow.Admin" />
        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:theme="@style/Theme.Cineflow.Admin" />
        <activity android:name=".ui.more.UserContentListActivity" />
        <activity android:name=".ui.more.AccountActivity" />
        <activity
            android:name=".ui.category.CategoryActivity"
            android:theme="@style/Theme.Cineflow.NoActionBar" />
    </application>

</manifest>
