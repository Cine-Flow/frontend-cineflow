<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_catalog_card"
    android:padding="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp">

        <ImageView
            android:id="@+id/iv_catalog_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/surface_card"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_gradient_bottom_up" />

        <TextView
            android:id="@+id/tv_catalog_premium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="@drawable/bg_catalog_premium_badge"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="@string/admin_premium_badge"
            android:textColor="#000000"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_catalog_year"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowRadius="3"
            android:shadowDx="0"
            android:shadowDy="1" />

    </FrameLayout>

    <TextView
        android:id="@+id/tv_catalog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingTop="8dp"
        android:paddingStart="2dp"
        android:paddingEnd="2dp" />

    <TextView
        android:id="@+id/tv_catalog_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"
        android:paddingStart="2dp"
        android:paddingEnd="2dp" />

</LinearLayout>
