<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_admin"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_form_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm tập mới"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Số tập *"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_episode_number"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/bg_input_field"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_tertiary"
        android:textSize="14sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:hint="1"
        android:singleLine="true"
        android:inputType="number"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tiêu đề tập *"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_episode_title"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/bg_input_field"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_tertiary"
        android:textSize="14sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:hint="Tập 1"
        android:singleLine="true"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Video tập phim"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/et_episode_video_url"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="Upload video..."
            android:singleLine="true"
            android:inputType="textUri" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_upload_ep_video"
            style="@style/Widget.Cineflow.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="📁"
            android:textSize="16sp"
            android:minWidth="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ep_cancel"
            style="@style/Widget.Cineflow.Button.Secondary"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Hủy"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ep_save"
            style="@style/Widget.Cineflow.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Lưu tập" />
    </LinearLayout>

</LinearLayout>
