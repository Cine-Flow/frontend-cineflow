<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_short_item"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_primary">

    <!-- Video player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:surface_type="texture_view"
        app:resize_mode="zoom" />

    <!-- Bottom gradient overlay for text readability (drawn behind text/buttons) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_gradient_bottom_up" />

    <!-- Bottom-left: Uploader + Title + Description -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom|start"
        android:paddingStart="16dp"
        android:paddingEnd="72dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_short_uploader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/tv_short_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/tv_short_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />
    </LinearLayout>

    <!-- Right-side action buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom|end"
        android:paddingEnd="12dp"
        android:paddingBottom="16dp"
        android:gravity="center_horizontal">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_user_avatar"
            android:layout_marginBottom="20dp"
            android:background="@drawable/shape_circle_orange"
            android:padding="2dp" />

        <!-- Like button -->
        <ImageView
            android:id="@+id/btn_like"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_heart_outline"
            android:layout_gravity="center_horizontal"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_like_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="20dp" />

        <!-- Comment button -->
        <ImageView
            android:id="@+id/btn_comment"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_comment"
            android:layout_gravity="center_horizontal"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detail_comments"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="20dp" />

        <!-- Share button -->
        <ImageView
            android:id="@+id/btn_share"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_share"
            android:layout_gravity="center_horizontal"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/player_btn_share"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</FrameLayout>
