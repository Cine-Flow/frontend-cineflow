<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_admin"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <!-- Title and Round -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/match_detail_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_dialog_round"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vòng 38"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="20dp" />

    <!-- Match Teams Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <!-- Home Team -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/iv_dialog_home_logo"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginBottom="8dp"
                android:src="@drawable/ic_launcher_foreground" />

            <TextView
                android:id="@+id/tv_dialog_home_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHE"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <!-- VS Section / Time -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/match_detail_vs"
                android:textColor="@color/brand_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_dialog_match_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22:00"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Away Team -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/iv_dialog_away_logo"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginBottom="8dp"
                android:src="@drawable/ic_launcher_foreground" />

            <TextView
                android:id="@+id/tv_dialog_away_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MUN"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- Stadium and Referee details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_input_field"
        android:padding="12dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tv_dialog_stadium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏟️ Sân vận động: Stamford Bridge"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_dialog_referee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏁 Trọng tài: Anthony Taylor"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_dialog_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ Đếm ngược: 02 giờ 15 phút"
            android:textColor="@color/brand_primary"
            android:textStyle="bold"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_close"
            style="@style/Widget.Cineflow.Button.Secondary"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/match_detail_close"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_remind"
            style="@style/Widget.Cineflow.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/match_detail_remind" />
    </LinearLayout>

</LinearLayout>
